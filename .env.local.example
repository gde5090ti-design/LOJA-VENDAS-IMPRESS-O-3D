# Copie este arquivo para .env.local e preencha com os dados do seu projeto Supabase
# Painel do Supabase > Project Settings > API

NEXT_PUBLIC_SUPABASE_URL=https://SEU-PROJETO.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUA-CHAVE-ANON-PUBLICA

# Usados para enviar o email de confirmação de pedido (opcional).
# Crie uma conta grátis em https://resend.com, verifique um domínio de envio
# e gere uma API key em Resend > API Keys.
# ATENÇÃO: essas duas variáveis NÃO devem começar com NEXT_PUBLIC_ — são secretas
# e só são usadas no servidor (na rota app/api/enviar-confirmacao).
RESEND_API_KEY=re_SUACHAVE
RESEND_FROM_EMAIL=Núcleo <pedidos@seudominio.com>
